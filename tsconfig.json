{
	"extends": [
		"@tsconfig/node-ts/tsconfig.json",
		"@tsconfig/strictest/tsconfig.json"
	],
	"compilerOptions": {
		"target": "es2023",
		"lib": ["ES2023", "DOM"],
		"moduleDetection": "force",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node", "vite/client"],
		"exactOptionalPropertyTypes": false,
		"noEmit": true
	}
}
